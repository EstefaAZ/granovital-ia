# granovital_login/.env.example  —  BUG-001/002/003 FIX
DEBUG=False
JWT_SECRET_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_SEGURA_DE_64_CHARS_MINIMO
JWT_ALGORITHM=HS256
DB_HOST=localhost
DB_PORT=3306
DB_NAME=granovital_ia
DB_USER=root
DB_PASSWORD=TU_PASSWORD_MYSQL_AQUI
REDIS_HOST=localhost
REDIS_PORT=6379
ALLOWED_ORIGINS=http://localhost:5173
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ── Email (SMTP) ──────────────────────────────────────────
# Configurar para envío real de correos
EMAIL_ENABLED=false
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=tu-email@gmail.com
EMAIL_SMTP_PASSWORD=tu-app-password
EMAIL_FROM=noreply@granovitalia.com
EMAIL_FROM_NAME=GranoVital IA

# ── Verificación de email ──────────────────────────────────
EMAIL_VERIFICATION_CODE_EXPIRE_MINUTES=15
EMAIL_VERIFICATION_CODE_LENGTH=6

# ── Google OAuth ──────────────────────────────────────────
# Obtener credenciales en: https://console.cloud.google.com/
# Crear un proyecto y configurar OAuth 2.0
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
