# =============================================================
# GranoVital IA — Variables de entorno
# Copiar este archivo como .env y completar los valores reales
# NUNCA subir el .env real al repositorio
# =============================================================

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=granovital_ia
DB_USER=granovital_user
DB_PASSWORD=tu_password_seguro_aqui

# JWT — Generar con: openssl rand -hex 32
JWT_SECRET_KEY=cambia_esto_por_una_clave_de_64_caracteres_minimo_muy_segura_aqui
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis (para caché de tokens y blacklist)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Configuración general
APP_NAME=GranoVital IA
APP_VERSION=1.0.0
DEBUG=False
ALLOWED_ORIGINS=http://localhost:3000,https://granovital.co

# Máximo intentos de login fallidos antes de suspender cuenta
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
