# modulo_04_ia / .env.example
# Copie como .env y ajuste los valores

DATABASE_URL=mysql+pymysql://granovital:granovital123@localhost:3306/granovital_db

# JWT - debe coincidir con Modulo 01
SECRET_KEY=cambia-esta-clave-en-produccion
ALGORITHM=HS256

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# URL del Modulo 03 (no usada en esta version - consulta directa a BD)
URL_MODULO_MONITOREO=http://localhost:8003/api/v1

# RNF-01 - timeout de inferencia en segundos (max 4.5 para cumplir 5s total)
TIMEOUT_INFERENCIA_SEG=4.5

# Imagen maxima: 10 MB
IMAGEN_MAX_BYTES=10485760
IMAGEN_TIPOS_PERMITIDOS=image/jpeg,image/png,image/webp

# RNF-08 - directorio con archivos .h5 o .pt de modelos entrenados
DIR_MODELOS=app/ia/modelos

# Umbral minimo de confianza para aceptar un diagnostico
UMBRAL_CONFIANZA_MINIMA=0.60

# RN-03 - horas maximas para datos del M03
HORAS_DATOS_VALIDOS=24
