# modulo_05_trazabilidad / .env.example
# Copie como .env y ajuste valores

DATABASE_URL=mysql+pymysql://granovital:granovital123@localhost:3306/granovital_db

# JWT - debe coincidir con Modulo 01
SECRET_KEY=cambia-esta-clave-en-produccion
ALGORITHM=HS256

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# URL base del sistema (se incluye en el QR publico - RN-05)
URL_BASE_SISTEMA=http://localhost:3000

# RN-04: sal para el hash de integridad (mantener secreta en produccion)
HASH_INTEGRIDAD_SAL=granovital-trazabilidad-2025

# RF-11: umbrales de secado CENICAFE (Avance Tecnico 359)
SECADO_TEMP_MIN_OPTIMA=35.0
SECADO_TEMP_MAX_OPTIMA=45.0
SECADO_TEMP_CRITICA=55.0
SECADO_HORAS_MINIMAS=72
SECADO_HUMEDAD_OBJETIVO=11.0

# RF-12: clasificacion FNC
HUMEDAD_MAX_EXPORTACION=12.0
DEFECTOS_MAX_SUPREMO=0
DEFECTOS_MAX_EXTRA=4
DEFECTOS_MAX_EXCELSO=8
