# ==============================================================
# modulo_03_monitoreo / .env.example
# Copie este archivo como .env y ajuste los valores
# ==============================================================

APP_NAME=GranoVital IA - Modulo Monitoreo
APP_VERSION=1.0.0
DEBUG=False

# Base de datos MySQL compartida con todos los modulos
DATABASE_URL=mysql+pymysql://granovital:granovital123@localhost:3306/granovital_db

# JWT - debe coincidir exactamente con el Modulo 01 de Autenticacion
SECRET_KEY=cambia-esta-clave-en-produccion
ALGORITHM=HS256

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# RN-03 - horas maximas para considerar un dato como valido
# Si la ultima lectura supera este valor, el modulo de IA
# rechazara generar recomendaciones de riego y fertilizacion
HORAS_DATOS_VALIDOS=24

# MQTT - RNF-09 Interoperabilidad con sensores IoT
# En zonas sin broker MQTT el sistema opera en modo manual (RNF-10)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_AMBIENTAL=granovital/cultivo/+/ambiental
MQTT_TOPIC_SUELO=granovital/cultivo/+/suelo
